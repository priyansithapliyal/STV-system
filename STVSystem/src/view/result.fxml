<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<VBox spacing="20"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ResultController"
      styleClass="root"
      prefWidth="700"
      prefHeight="650">

    <!-- BACK BUTTON -->
    <Button text="← Back"
            onAction="#goBack"/>

    <!-- TITLE -->
    <Label text="Election Results"
           styleClass="title"/>

    <!-- RESULT TABLE -->
    <TableView fx:id="resultTable"
               prefHeight="220"
               prefWidth="500">

        <columns>

            <TableColumn fx:id="nameColumn"
                         text="Candidate Name"
                         prefWidth="250"/>

            <TableColumn fx:id="votesColumn"
                         text="Votes"
                         prefWidth="250"/>

        </columns>

    </TableView>

    <!-- BAR CHART -->
    <BarChart fx:id="resultChart"
              prefWidth="500"
              prefHeight="300">

        <xAxis>
            <CategoryAxis label="Candidates"/>
        </xAxis>

        <yAxis>
            <NumberAxis label="Votes"/>
        </yAxis>

    </BarChart>

    <!-- SUMMARY -->
    <Label fx:id="totalCandidatesLabel"
           text="Total Candidates: 0"/>

    <Label fx:id="totalVotesLabel"
           text="Total Votes: 0"/>

    <!-- WINNER -->
    <Label fx:id="winnerLabel"
           text="Winner will appear here"
           styleClass="winner-label"/>

    <!-- RESET BUTTON -->
    <Button text="Reset Election"
            onAction="#resetElection"/>

</VBox>